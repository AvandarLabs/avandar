{
  "deno.suggest.autoImports": true,
  "deno.suggest.imports.autoDiscover": true,
  "deno.organizeImports.enabled": true,
  "deno.lint": false,
  "deno.enablePaths": [
    "./supabase/functions",
    "./shared",
    "./packages/clients",
    "./packages/logger",
    "./packages/models",
    "./packages/modules",
    "./packages/utils"
  ],
  "deno.config": "./deno.json",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "stylelint.configFile": "stylelint.config.js",
  "stylelint.validate": ["css", "tailwindcss"],
  "css.validate": false,
  "postcss.validate": false,
  "typescript.tsdk": "./node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "cssVariables.lookupFiles": [
    "**/*.css",
    "**/*.scss",
    "**/*.sass",
    "**/*.less",
    "node_modules/@mantine/core/styles.css",
    "node_modules/mantine/styles/global.css"
  ]
}
