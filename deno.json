{
  "__comment": "This is the Deno config for the local repo. It is used only to make Deno type checking work locally. It is not loaded into Supabase edge functions",
  "workspace": [
    "./packages/shared/clients",
    "./packages/shared/logger",
    "./packages/shared/models",
    "./packages/shared/modules",
    "./packages/shared/utils",
    "./supabase/functions/_shared",
    "./supabase/functions/google-auth",
    "./supabase/functions/google-auth-callback",
    "./supabase/functions/google-sheets",
    "./supabase/functions/healthz",
    "./supabase/functions/polar-public",
    "./supabase/functions/queries",
    "./supabase/functions/subscriptions",
    "./supabase/functions/waitlist",
    "./supabase/functions/workspaces"
  ],
  "imports": {
    "$/": "./shared/",
    "@sbfn/": "./supabase/functions/",
    "@clients/": "./packages/shared/clients/src/",
    "@logger/": "./packages/shared/logger/src/",
    "@models/": "./packages/shared/models/src/",
    "@modules/": "./packages/shared/modules/src/",
    "@utils/": "./packages/shared/utils/src/",
    "jose": "jsr:@panva/jose@6"
  },
  "compilerOptions": {
    "experimentalDecorators": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["deno.ns", "dom", "dom.iterable"],
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    "types": ["react", "react/jsx-runtime"]
  }
}
