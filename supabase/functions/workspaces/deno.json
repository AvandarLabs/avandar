{
  "imports": {
    "$/": "../../../shared/",
    "@clients/": "../../../packages/shared/clients/src/",
    "@logger/": "../../../packages/shared/logger/src/",
    "@models/": "../../../packages/shared/models/src/",
    "@modules/": "../../../packages/shared/modules/src/",
    "@utils/": "../../../packages/shared/utils/src/",
    "@react-email/components": "npm:@react-email/components@0",
    "@react-email/render": "npm:@react-email/render@1",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@2",
    "@upstash/ratelimit": "npm:@upstash/ratelimit@2",
    "@upstash/redis": "npm:@upstash/redis@1",
    "dayjs": "npm:dayjs@1.11.13",
    "dayjs/plugin/utc": "npm:dayjs@1.11.13/plugin/utc.js",
    "dayjs/plugin/timezone": "npm:dayjs@1.11.13/plugin/timezone.js",
    "react": "npm:react@19",
    "resend": "npm:resend@6",
    "ts-pattern": "npm:ts-pattern@5",
    "type-fest": "npm:type-fest@5",
    "zod": "npm:zod@4"
  },
  "compilerOptions": {
    "experimentalDecorators": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["deno.ns", "dom", "dom.iterable"],
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    "types": ["react", "react/jsx-runtime"]
  }
}
