{
  "imports": {
    "$/": "../../../shared/",
    "@clients/": "../../../packages/shared/clients/src/",
    "@logger/": "../../../packages/shared/logger/src/",
    "@models/": "../../../packages/shared/models/src/",
    "@modules/": "../../../packages/shared/modules/src/",
    "@utils/": "../../../packages/shared/utils/src/",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@2",
    "googleapis": "npm:googleapis@154",
    "zod": "npm:zod@4"
  },
  "compilerOptions": {
    "experimentalDecorators": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["deno.ns", "dom", "dom.iterable"],
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    "types": ["react", "react/jsx-runtime"]
  }
}
