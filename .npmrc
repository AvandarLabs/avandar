# Types need to be hoisted for editor/TS resolution
# (this is a pnpm default, listed for clarity)
public-hoist-pattern[]=@types/*

# ESLint plugins resolve each other from the config location
public-hoist-pattern[]=*eslint*

# Stylelint plugins
public-hoist-pattern[]=*stylelint*

# PostCSS + TailwindCSS plugins need to be resolvable by postcss
public-hoist-pattern[]=postcss*
public-hoist-pattern[]=autoprefixer
public-hoist-pattern[]=tailwindcss

# TypeScript language service plugins (e.g. CSS modules)
public-hoist-pattern[]=typescript-plugin-css-modules