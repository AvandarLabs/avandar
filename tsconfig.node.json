{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ESNext"],
    "typeRoots": ["./node_modules/@types"],
    "incremental": true
  },
  "include": [
    "vite.config.ts",
    ".ava/**/*.ts",
    "apps/dev-fanout-server/src/**/*.ts",
    "apps/ava-cli/src/**/*.ts"
  ],
  "exclude": ["supabase/functions"]
}
